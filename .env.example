# Variables para Netlify → Site settings → Environment variables
# También puedes usar este archivo como .env local con: netlify dev

# Connection string de Neon (Dashboard → Connect → Connection string)
DATABASE_URL=postgresql://usuario:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# PIN del panel admin (admin.html)
ADMIN_PIN=xv2025

# Tu dominio de Netlify (ej. https://tarjeta-naela.netlify.app)
ALLOWED_ORIGIN=https://tu-sitio.netlify.app
